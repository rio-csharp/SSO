@model MySso.Contracts.Identity.UserProfileSummary

@{
    ViewData["Title"] = "My Profile";
}

<div class="row">
    <div class="col-lg-8">
        <h1 class="h3 mb-3">My Profile</h1>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.GivenName @Model.FamilyName</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Active" : "Disabled")</dd>
                    <dt class="col-sm-4">Roles</dt>
                    <dd class="col-sm-8">@(Model.Roles.Count == 0 ? "None" : string.Join(", ", Model.Roles))</dd>
                    <dt class="col-sm-4">Last Sign-In</dt>
                    <dd class="col-sm-8">@(Model.LastSignedInAtUtc?.ToString("u") ?? "Never")</dd>
                    <dt class="col-sm-4">Last IP</dt>
                    <dd class="col-sm-8">@(Model.LastSignedInIpAddress ?? "N/A")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>